{
    /* Editor **/
    /** On Save **/
    "editor.formatOnSave": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "notebook.formatOnSave.enabled": true,
    /* Extensions **/
    /** Python-related **/
    "python.analysis.completeFunctionParens": true,
    "python.analysis.inlayHints.callArgumentNames": "all",
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.pytestParameters": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.typeEvaluation.deprecateTypingAliases": false,
    "python.analysis.typeEvaluation.strictDictionaryInference": true,
    "python.analysis.typeEvaluation.strictListInference": true,
    "python.analysis.typeEvaluation.strictSetInference": true,
    "python.languageServer": "Default",
    "python.pyrefly.disableLanguageServices": true,
    "python.testing.autoTestDiscoverOnSaveEnabled": false,
    /* Editor settings by language **/
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "notebook.codeActionsOnSave": {
        "notebook.source.fixAll.python": "explicit",
        "notebook.source.organizeImports": "explicit"
    },
    "notebook.defaultFormatter": "charliermarsh.ruff",
    "notebook.experimental.generate": false,
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.fixAll.python": "explicit",
            "source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "charliermarsh.ruff",
    },
}
